---

<section id="features" class="py-24 bg-white">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Section header -->
    <div class="text-center max-w-2xl mx-auto mb-16 space-y-4">
      <span class="inline-block bg-brand-100 text-brand-700 text-xs font-bold uppercase tracking-widest px-3 py-1.5 rounded-full">
        État du projet
      </span>
      <h2 class="text-3xl sm:text-4xl font-extrabold text-slate-900">
        Fonctionnalités actuelles et à venir
      </h2>
      <p class="text-lg text-slate-500 leading-relaxed">
        Municeo est en développement actif.<br class="sm:hidden" />
        Découvrez ce qui est déjà implémenté, ce qui est prévu, et notre vision pour l'avenir.
      </p>
    </div>

    <!-- Feature tabs -->
    <div class="flex flex-wrap justify-center gap-3 mb-12">
      <button class="feature-tab active px-6 py-3 rounded-full font-semibold text-sm bg-brand-600 text-white transition-colors" data-tab="in-progress">
        🚧 En cours de développement
      </button>
      <button class="feature-tab px-6 py-3 rounded-full font-semibold text-sm bg-slate-100 text-slate-600 hover:bg-slate-200 transition-colors" data-tab="future">
        🔮 Futur
      </button>
      <button class="feature-tab px-6 py-3 rounded-full font-semibold text-sm bg-slate-100 text-slate-600 hover:bg-slate-200 transition-colors" data-tab="behavior">
        ⚙️ Comportements
      </button>
    </div>

    <!-- In Progress Tab -->
    <div class="feature-content active" id="in-progress">
      <div class="grid md:grid-cols-2 gap-8">
        {inProgressFeatures.map((feature) => (
          <div class="bg-white border border-slate-100 rounded-2xl p-8 shadow-sm hover:shadow-md transition-shadow">
            <div class="flex items-start gap-4 mb-4">
              <div class="text-3xl">{feature.icon}</div>
              <div class="flex-1">
                <h3 class="text-xl font-bold text-slate-900">{feature.title}</h3>
                <span class="inline-block text-xs font-semibold px-2 py-1 rounded-full bg-yellow-100 text-yellow-800 mt-2">
                  {feature.status}
                </span>
              </div>
            </div>
            <p class="text-slate-600 mb-4 text-sm leading-relaxed">{feature.description}</p>
            {feature.items && (
              <ul class="space-y-2">
                {feature.items.map((item) => (
                  <li class="flex items-start gap-2 text-sm text-slate-600">
                    <span class="text-green-500 font-bold mt-0.5">✓</span>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            )}
          </div>
        ))}
      </div>
    </div>

    <!-- Future Tab -->
    <div class="feature-content hidden" id="future">
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {futureFeatures.map((feature) => (
          <div class="bg-white border border-slate-100 rounded-2xl p-8 shadow-sm hover:shadow-md transition-shadow">
            <div class="flex items-start gap-4 mb-4">
              <div class="text-3xl">{feature.icon}</div>
              <div class="flex-1">
                <h3 class="text-xl font-bold text-slate-900">{feature.title}</h3>
                <span class="inline-block text-xs font-semibold px-2 py-1 rounded-full bg-blue-100 text-blue-800 mt-2">
                  {feature.status}
                </span>
              </div>
            </div>
            <p class="text-slate-600 text-sm leading-relaxed">{feature.description}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- Behavior Tab -->
    <div class="feature-content hidden" id="behavior">
      <div class="grid md:grid-cols-2 gap-8">
        {behaviorFeatures.map((feature) => (
          <div class="bg-white border border-slate-100 rounded-2xl p-8 shadow-sm hover:shadow-md transition-shadow">
            <div class="flex items-start gap-4 mb-4">
              <div class="text-3xl">{feature.icon}</div>
              <div class="flex-1">
                <h3 class="text-xl font-bold text-slate-900">{feature.title}</h3>
                <span class="inline-block text-xs font-semibold px-2 py-1 rounded-full bg-purple-100 text-purple-800 mt-2">
                  {feature.status}
                </span>
              </div>
            </div>
            <p class="text-slate-600 mb-4 text-sm leading-relaxed">{feature.description}</p>
            {feature.explainer && (
              <div class="mb-4 p-3 bg-slate-50 border-l-4 border-brand-400 rounded">
                <strong class="text-sm text-brand-700 block mb-2">{feature.explainer.title}</strong>
                <p class="text-xs text-slate-600 leading-relaxed">{feature.explainer.text}</p>
              </div>
            )}
            {feature.items && (
              <ul class="space-y-2">
                {feature.items.map((item) => (
                  <li class="flex items-start gap-2 text-sm text-slate-600">
                    <span class="text-green-500 font-bold mt-0.5">✓</span>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            )}
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  const tabs = document.querySelectorAll('.feature-tab');
  const contents = document.querySelectorAll('.feature-content');

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      const targetTab = tab.getAttribute('data-tab');

      // Remove active class
      tabs.forEach(t => {
        t.classList.remove('active', 'bg-brand-600', 'text-white');
        t.classList.add('bg-slate-100', 'text-slate-600', 'hover:bg-slate-200');
      });
      contents.forEach(c => c.classList.add('hidden'));

      // Add active class
      tab.classList.add('active', 'bg-brand-600', 'text-white');
      tab.classList.remove('bg-slate-100', 'text-slate-600', 'hover:bg-slate-200');
      document.getElementById(targetTab).classList.remove('hidden');
    });
  });
</script>
