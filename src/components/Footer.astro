---
// Footer component
const currentYear = new Date().getFullYear();
---

<footer class="bg-slate-950 text-slate-400 py-12">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-8 mb-12">

      <!-- Brand column -->
      <div class="lg:col-span-2 space-y-4">
        <a href="/" class="flex items-center gap-2 font-bold text-xl text-white hover:text-brand-300 transition-colors w-fit">
          <svg viewBox="0 0 32 32" class="w-8 h-8" aria-hidden="true">
            <rect width="32" height="32" rx="8" fill="#3b86fc"/>
            <path d="M16 6 C11 6 7 10 7 15 C7 21 16 28 16 28 C16 28 25 21 25 15 C25 10 21 6 16 6 Z" fill="white"/>
            <circle cx="16" cy="15" r="4" fill="#3b86fc"/>
          </svg>
          Municeo
        </a>
        <p class="text-sm text-slate-400 leading-relaxed max-w-sm">
          Plateforme participative open source permettant aux habitants de signaler des incivilités directement à leur municipalité.
        </p>
        <p class="text-xs text-slate-500">
          Licence AGPL-3.0 · Non commercial
        </p>
      </div>

      <!-- Project links -->
      <div class="space-y-4">
        <h3 class="text-sm font-semibold text-white uppercase tracking-wider">Projet</h3>
        <ul class="space-y-2 text-sm">
          <li>
            <a href="https://github.com/municeo/municeo" target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors">
              Code source
            </a>
          </li>
          <li>
            <a href="https://github.com/municeo/municeo/blob/main/docs/specifications.md" target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors">
              Spécifications
            </a>
          </li>
          <li>
            <a href="https://github.com/municeo/municeo/blob/main/PLAN.md" target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors">
              Plan de développement
            </a>
          </li>
          <li>
            <a href="https://github.com/municeo/municeo/blob/main/CONTRIBUTING.md" target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors">
              Contribuer
            </a>
          </li>
        </ul>
      </div>

      <!-- Page links -->
      <div class="space-y-4">
        <h3 class="text-sm font-semibold text-white uppercase tracking-wider">Navigation</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="#features" class="hover:text-white transition-colors">Fonctionnalités</a></li>
          <li><a href="#community" class="hover:text-white transition-colors">Communauté</a></li>
          <li><a href="#how-it-works" class="hover:text-white transition-colors">Comment ça marche</a></li>
          <li><a href="#civic-tech" class="hover:text-white transition-colors">Civic Tech</a></li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="border-t border-slate-800 pt-8 flex flex-col sm:flex-row items-center justify-between gap-4 text-sm">
      <p class="text-slate-500">
        &copy; {currentYear} Municeo · Tous droits réservés
      </p>
      <p class="text-slate-500">
        Fait avec ❤️ pour les communes
      </p>
    </div>
  </div>
</footer>
